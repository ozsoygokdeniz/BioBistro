# Supabase PostgreSQL Bağlantı URL'si
# Supabase Dashboard > Database > Connection String (URI formatı) bölümünden alın
SUPABASE_DB_URL="postgresql://postgres:SUPABASE_SIFRENIZ@db.PROJE_ID.supabase.co:5432/postgres"

# AWS Bedrock (Claude) - NOT: Bedrock "API key" ile degil IAM credential ile calisir.
# Asagidakilerden birini ayarlamaniz yeterli:
# 1) IAM Access Key/Secret (lokalde gelistirme icin)
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# Opsiyonel (temporary credentials kullaniyorsaniz)
AWS_SESSION_TOKEN=""
AWS_REGION="us-east-1"

# 2) Alternatif: AWS CLI profili (AWS_PROFILE) kullanacaksaniz yukaridaki key'leri bos birakabilirsiniz
# AWS_PROFILE="default"

# Eski deneme degiskeni (KULLANMAYIN) - Bedrock bunu okumaz:
# AWS_BEARER_TOKEN_BEDROCK=""

# JWT İmzalama Anahtarı (Gizli, rastgele uzun bir string olmalı)
# Terminalde: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="bu_anahtari_mutlaka_degistir_ve_kimseyle_paylasma"
